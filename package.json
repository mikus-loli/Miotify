{
  "name": "miotify",
  "version": "1.0.0",
  "description": "Real-time message push server with web UI",
  "main": "src/index.js",
  "scripts": {
    "build": "cd web && npm install && npm run build",
    "start": "node src/index.js",
    "dev:server": "node --watch src/index.js",
    "dev:web": "cd web && npm run dev",
    "dev": "concurrently -n server,web -c blue,green \"npm run dev:server\" \"npm run dev:web\"",
    "prod": "npm run build && npm start"
  },
  "keywords": [
    "push",
    "websocket",
    "message",
    "gotify"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.7",
    "sql.js": "^1.14.1",
    "uuid": "^14.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
